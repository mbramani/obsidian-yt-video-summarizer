{
	"name": "obsidian-yt-video-summarizer-waghmare",
	"version": "1.2.1",
	"description": "Maintained fork: Summarize YouTube videos using AI. Fixed YouTube transcript 400 error.",
	"main": "main.js",
	"scripts": {
		"build": "tsc -noEmit -skipLibCheck && esbuild src/main.ts --bundle --external:obsidian --format=cjs --platform=node --outfile=main.js",
		"version": "node -e \"let m=require('./manifest.json'); m.version=process.env.npm_package_version; require('fs').writeFileSync('./manifest.json', JSON.stringify(m, null, '\\t'))\""
	},
	"keywords": [
		"obsidian",
		"youtube",
		"summarizer",
		"gemini",
		"ai"
	],
	"author": "Waghmare",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.25.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.40.0",
		"@google/generative-ai": "^0.24.0",
		"node-html-parser": "^7.0.1",
		"openai": "^4.96.0",
		"protobufjs": "^7.5.3"
	}
}
